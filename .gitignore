# OS and editor files
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log
logs/

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local
frontend/.eslintcache

# Backend runtime data and local binaries
data/
backend/data/*
!backend/data/.gitkeep
backend/opensync
backend/server
backend/*.db
backend/*.db-shm
backend/*.db-wal
backend/*.key

# Embedded frontend build output generated by `npm run build`
backend/cmd/server/web/*
!backend/cmd/server/web/.gitkeep

# Test and coverage output
coverage/
*.out
